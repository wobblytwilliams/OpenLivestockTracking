String cmdLine;

static int32_t msc_read_cb (uint32_t lba, void* buffer, uint32_t bufsize) {
  if (!mscReady || !sdOK) return -1;
  uint32_t count = bufsize / 512;
  SdCard* card = sd.card();
  if (!card) return -1;
  for (uint32_t i=0; i<count; i++) {
    if (!card->readSector(lba + i, (uint8_t*)buffer + i*512)) return -1;
  }
  return (int32_t)bufsize;
}
static int32_t msc_write_cb (uint32_t lba, uint8_t* buffer, uint32_t bufsize) {
  if (!mscReady || !sdOK) return -1;
  uint32_t count = bufsize / 512;
  SdCard* card = sd.card();
  if (!card) return -1;
  for (uint32_t i=0; i<count; i++) {
    if (!card->writeSector(lba + i, (uint8_t*)buffer + i*512)) return -1;
  }
  return (int32_t)bufsize;
}
static void msc_flush_cb (void) {
  if (!sdOK) return;
  SdCard* card = sd.card();
  if (card) card->syncDevice();
}
static bool msc_startstop_cb (uint8_t power_condition, bool start, bool load_eject) {
  (void)power_condition; (void)load_eject;
  mscReady = start && sdOK;
  return true;
}

void setMSC(bool on){
  if (on == mscMode) {
    Serial.print("MSC already "); Serial.println(on ? "ON" : "OFF");
    return;
  }
  if (on) {
    Serial.println("MSC ON: stopping logging, flushing & closing files…");
    stopBleScan();
    flushBuffers(true, FR_MSC);      // writes + closes + leaves bus asleep

    // Now bring bus up, mount SD for MSC access and keep it awake
    sd_spi_bus_wake();
    sdOK = sd.begin(sdCfg);
    if (!sdOK || !sd.card()){
      Serial.println("MSC ON: SD not initialized/absent.");
      sd_spi_bus_sleep();
      return;
    }
    uint32_t bc = sd.card()->sectorCount();
    usb_msc.setCapacity(bc ? bc : 8, 512);
    mscReady = true;
    usb_msc.setUnitReady(true);
    mscMode = true;

    Serial.println("MSC ON: re-enumerating USB to prompt host mount…");
    TinyUSBDevice.detach(); delay(300); TinyUSBDevice.attach();
    Serial.println("MSC ON: SD should now appear on the PC.");
  } else {
    Serial.println("MSC OFF: unmounting from host…");
    mscReady = false;
    usb_msc.setUnitReady(false);
    delay(10);
    TinyUSBDevice.detach(); delay(300); TinyUSBDevice.attach();

    mscMode = false;

    // After MSC, put the SPI bus back to sleep
    sd_spi_bus_sleep();

    Serial.println("MSC OFF: resuming logging.");
    lastBleCycleStartMs = millis() - BLE_CYCLE_PERIOD_MS;
    lastGpsSampleMs     = millis() - GPS_SAMPLE_PERIOD_MS;
  }
}

void handleSerialCommands(){
  while (Serial.available()){
    char c = (char)Serial.read();
    if (c == '\r') continue;
    if (c == '\n'){
      cmdLine.trim();
      if (cmdLine.length()){
        String up = cmdLine; up.toUpperCase();
        if (up == "MSC ON" || up == "USBMSC 1" || up == "MSC=1") setMSC(true);
        else if (up == "MSC OFF" || up == "USBMSC 0" || up == "MSC=0") setMSC(false);
        else if (up == "STATUS"){
          Serial.print("MSC="); Serial.print(mscMode?1:0);
          Serial.print(" SD=");  Serial.print(sdOK?1:0);
          Serial.print(" files(");
          Serial.print((bool)accelFile); Serial.print(',');
          Serial.print((bool)gpsFile);   Serial.print(',');
          Serial.print((bool)bleFile);   Serial.print(')');
          Serial.print(" events="); Serial.print(g_event_count);
          Serial.print('/'); Serial.print(g_event_cap);
          Serial.print(" %full="); Serial.print((int)ring_fullness_pct());
          Serial.print(" usedB="); Serial.print((unsigned long)ring_used_bytes());
          Serial.print('/'); Serial.println((unsigned long)RING_CAP_BYTES);
        } else {
          Serial.print("Unknown cmd: "); Serial.println(cmdLine);
          Serial.println("Use: 'MSC ON' or 'MSC OFF' (or 'USBMSC 1/0')");
        }
      }
      cmdLine = "";
    } else {
      cmdLine += c;
      if (cmdLine.length() > 64) cmdLine = "";
    }
  }
}

