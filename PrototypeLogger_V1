// SD flush timing + helpers
// ====================================================================
bool     gpsSessionActive = false;
uint32_t lastGpsSampleMs  = 0;
uint32_t acqDeadline      = 0;
bool     retryUsed        = false;

uint32_t lastFlushMs = 0;

bool inQuietMode(){
  uint32_t now = millis();
  bool justSynced = (now < noFlushUntilMs);
  bool acquiring = gpsSessionActive && ((!timeSynced) || (now - lastValidRmcMs > FIX_LOSS_GRACE_MS));
  return acquiring || justSynced;
}

void flushBuffers(bool emergency, uint8_t reason_code){
  // When mscMode is active we don’t log (except the pre-MSC flush call).
  if (mscMode && reason_code != FR_MSC) return;
  if (!emergency && inQuietMode()) return;

  if (!sd_session_begin()) return;

  size_t n_acc = 0, n_gps = 0, n_ble = 0;
  static size_t acc_total = 0, gps_total = 0, ble_total = 0;

  size_t beforeBytes = ring_used_bytes();
  uint32_t t0 = millis();

  for(size_t i=0;i<g_event_count;i++){
    const LogEvent& ev = g_events[i];
    switch(ev.type){
      case EV_ACCEL: {
        const auto& r = ev.p.accel;
        if(accelFile){
          accelFile.print(r.t_ms); accelFile.print(',');
          if (r.unix_s) accelFile.print(r.unix_s);
          accelFile.print(',');
          accelFile.print(r.ax,4); accelFile.print(',');
          accelFile.print(r.ay,4); accelFile.print(',');
          accelFile.println(r.az,4);
          n_acc++;
        }
      } break;
      case EV_GPS: {
        const auto& r = ev.p.gps;
        if(gpsFile){
          gpsFile.print(r.t_ms); gpsFile.print(',');
          if (r.unix_s) gpsFile.print(r.unix_s);
          gpsFile.print(',');
          if(isnan(r.lat)) gpsFile.print("NaN"); else gpsFile.print(r.lat,6);
          gpsFile.print(',');
          if(isnan(r.lon)) gpsFile.print("NaN"); else gpsFile.print(r.lon,6);
          gpsFile.print(',');
          gpsFile.print(r.fix); gpsFile.print(',');
          gpsFile.println(r.sync);
          n_gps++;
        }
      } break;
      case EV_BLE: {
        const auto& r = ev.p.ble;
        if(bleFile){
          char macStr[18]; macToStrMSB(r.mac, macStr);
          bleFile.print(r.t_ms); bleFile.print(',');
          if (r.unix_s) bleFile.print(r.unix_s);
          bleFile.print(',');
          bleFile.print(macStr); bleFile.print(',');
          bleFile.println(r.rssi);
          n_ble++;
        }
      } break;
    }
  }

  sd_session_end();

  g_event_count = 0;
  lastFlushMs   = millis();

  acc_total += n_acc; gps_total += n_gps; ble_total += n_ble;

  uint32_t dt = lastFlushMs - t0;
  Serial.print("[FLUSH] ");
  Serial.print(emergency ? "EMERGENCY" : "normal");
  Serial.print(" reason="); Serial.print(flush_reason_u8(reason_code));
  Serial.print(" wrote A="); Serial.print(n_acc);
  Serial.print(" G=");       Serial.print(n_gps);
  Serial.print(" B=");       Serial.print(n_ble);
  Serial.print(" total=");   Serial.print(n_acc + n_gps + n_ble);
  Serial.print(" cum=(");    Serial.print(acc_total); Serial.print(',');
                           Serial.print(gps_total); Serial.print(',');
                           Serial.print(ble_total); Serial.print(')');
  Serial.print(" bytes_before="); Serial.print((unsigned long)beforeBytes);
  Serial.print(" pct_before=");
  Serial.print(RING_CAP_BYTES ? (int)((beforeBytes * 100U) / RING_CAP_BYTES) : 0);
  Serial.print("% dt_ms=");  Serial.println((int)dt);
}

