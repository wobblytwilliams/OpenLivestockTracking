// ====================================================================
// 64-bit monotonic uptime
// ====================================================================
uint64_t uptime_ms64(){
  static uint32_t prev32 = 0;
  static uint64_t high   = 0;
  uint32_t now32 = millis();
  if (now32 < prev32) high += (1ULL << 32); // wrap
  prev32 = now32;
  return high | now32;
}

// ====================================================================
// Disciplined UTC clock (UTC in ms) + helpers
// ====================================================================
struct ClockDisc {
  double   scale    = 1.0;   // ms/ms (ppm correction)
  double   phase_ms = 0.0;   // UTC ms at t0_ms
  uint64_t t0_ms    = 0;     // uptime anchor (ms)
  bool     synced   = false; // received at least one valid GPS UTC
};
ClockDisc g_clock;

uint64_t utc_now_ms(){
  if (!g_clock.synced) return 0;
  uint64_t now_ms = uptime_ms64();
  double dt = (double)(now_ms - g_clock.t0_ms);
  double t_ms = g_clock.phase_ms + g_clock.scale * dt;
  if (t_ms < 0) t_ms = 0;
  return (uint64_t)(t_ms + 0.5);
}
uint32_t utc_now_s(){ return (uint32_t)(utc_now_ms() / 1000ULL); }
uint16_t utc_now_ms_of_sec(){ return (uint16_t)(utc_now_ms() % 1000ULL); }
bool     utc_time_valid(){ return g_clock.synced; }

// Y/M/D → UNIX ms
static const int mdays[12]={31,28,31,30,31,30,31,31,30,31,30,31};
bool isLeap(int y){ return (y%4==0 && y%100!=0) || (y%400==0); }
int  fullYearFromYY(int yy){ return 2000 + (yy%100); }
uint32_t daysSince1970(int y,int m,int d){
  uint32_t days=0; for(int yr=1970; yr<y; ++yr) days += isLeap(yr)?366:365;
  for(int i=1;i<m;i++){ days += mdays[i-1]; if(i==2 && isLeap(y)) days++; }
  return days + (d-1);
}
uint64_t unix_ms_from_ymdhms(int y,int m,int d,int hh,int mm,int ss){
  return ((uint64_t)daysSince1970(y,m,d)*86400ULL + (uint64_t)hh*3600ULL + (uint64_t)mm*60ULL + (uint64_t)ss) * 1000ULL;
}
static inline bool plausibleYear(int yyyy){ return (yyyy >= 2020 && yyyy <= 2035); }

