extern "C" uint32_t sd_app_evt_wait(void);
static inline void lowPowerIdleUntil(uint32_t deadline_ms){
  while ((int32_t)(deadline_ms - millis()) > 0){
    sd_app_evt_wait(); // sleep until any event (BLE, timers, UART, etc.)
  }
}

#if !ACCEL_USE_FIFO_INT
static uint32_t g_accel_poll_period_ms = 750; // computed in setup()
static uint32_t nextAccelPollDue = 0;
#endif

void setup(){
  Serial.begin(USB_BAUD);
  uint32_t t0=millis(); while(!Serial && millis()-t0<2000){} // brief wait
  Serial.println("\n=== Logger + MSC + BLE + GPS duty-cycle + low-power (ADXL FIFO polling) ===");

  Wire.begin();
  Wire.setClock(400000); // faster I2C for burst FIFO reads
  Serial1.begin(GPS_BAUD);

  // ADXL345
  if(!adxl_init()) Serial.println("ADXL345 not found");
  else Serial.println("ADXL345 @ 12.5 Hz (low-power, FIFO STREAM) OK");

#if ACCEL_USE_FIFO_INT
  pinMode(ACCEL_INT_PIN, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(ACCEL_INT_PIN), accel_isr, RISING);
#endif

  // NOTE: do NOT mount/open SD here. We mount per-flush or when MSC is turned on.

  // --- MSC init (capacity will be updated when MSC is turned ON) ---
  usb_msc.setID("CQU", "ITSY SD", "1.0");
  usb_msc.setCapacity(8, 512); // placeholder; updated on MSC ON
  usb_msc.setReadWriteCallback(msc_read_cb, msc_write_cb, msc_flush_cb);
  usb_msc.setStartStopCallback(msc_startstop_cb);
  usb_msc.begin();
  usb_msc.setUnitReady(false);

  // --- BLE (Central scanner) ---
  Bluefruit.autoConnLed(false);
  Bluefruit.begin(0, 1);
  Bluefruit.setTxPower(-20);
  Bluefruit.Scanner.setRxCallback(scan_callback);
  Bluefruit.Scanner.useActiveScan(false);
  Bluefruit.Scanner.setInterval(
    BLE_UNITS(BLE_SCAN_INTERVAL_MS),
    BLE_UNITS(BLE_SCAN_WINDOW_MS)
  );

  // Start schedulers soon
  lastBleCycleStartMs = millis() - BLE_CYCLE_PERIOD_MS;
  lastGpsSampleMs     = millis() - GPS_SAMPLE_PERIOD_MS;

  // Allocate the unified ring from the allocator's current limit after init
  alloc_event_ring_from_heap();

#if !ACCEL_USE_FIFO_INT
  // Compute a safe poll period from ODR & watermark:
  const uint32_t wm_interval = (uint32_t)ACCEL_FIFO_WATERMARK * ACCEL_PERIOD_MS;           // time to reach WM
  const uint32_t slack       = (uint32_t)(32 - ACCEL_FIFO_WATERMARK) * ACCEL_PERIOD_MS;    // time from WM to overrun
  g_accel_poll_period_ms = (slack > 0) ? min(wm_interval/2, (slack*8)/10) : wm_interval/2; // conservative
  if (g_accel_poll_period_ms < 50) g_accel_poll_period_ms = 50;
  nextAccelPollDue = millis() + g_accel_poll_period_ms;
  Serial.print("ACCEL poll period = "); Serial.print(g_accel_poll_period_ms); Serial.println(" ms");
#endif

  // LEDs off
  pinMode(LED_BUILTIN, OUTPUT);
  digitalWrite(LED_BUILTIN, LOW);

  // Ensure SPI bus starts asleep
  sd_spi_bus_sleep();

  Serial.println("Type 'MSC ON' to mount SD over USB; 'MSC OFF' to resume logging.");
}

static inline uint32_t min3(uint32_t a, uint32_t b, uint32_t c){ return min(a, min(b, c)); }

void startGpsSession(){
  gpsWake();
  gpsSessionActive   = true;
  gpsSessionStart    = millis();
  gpsValid           = false;         // fresh-only
  syncEventFlag      = false;
  sawRmcThisSession  = false;
  acqDeadline        = gpsSessionStart + GPS_WARMUP_MS + GPS_FIX_TIMEOUT_MS;
  retryUsed          = false;
}
void stopGpsSession(){
  gpsStandby();
  gpsSessionActive = false;
}

void loop(){
  handleSerialCommands();

  // If MSC mode is ON, pause everything except command handling
  if (mscMode) {
    sd_app_evt_wait();
    return;
  }

  // Normal operation
  pumpGPS();

  // --- Service per-push flush hints ASAP (event-driven, low power) ---
  if (g_flushHint == 2) {                // emergency
    flushBuffers(true, FR_EMERGENCY);
    g_flushHint = 0;
  } else if (g_flushHint == 1) {         // threshold
    if (!inQuietMode()) flushBuffers(false, FR_THRESHOLD);
    g_flushHint = 0;
  }

  uint32_t now = millis();

  // ----- BLE scan scheduler -----
  if (!bleActive) {
    if (now - lastBleCycleStartMs >= BLE_CYCLE_PERIOD_MS) startBleScan();
  } else {
    if (now - bleStartMs >= BLE_ACTIVE_MS) stopBleScan();
  }

  // ----- GPS 3-minute scheduler with one-shot retry -----
  if (!gpsSessionActive) {
    if (now - lastGpsSampleMs >= GPS_SAMPLE_PERIOD_MS) {
      startGpsSession();
    }
  } else {
    bool warmed = (now - gpsSessionStart >= GPS_WARMUP_MS);
    bool timed  = (now >= acqDeadline);
    bool fresh  = (lastValidRmcMs >= gpsSessionStart);

    if (warmed && fresh && gpsValid) {
      // EV_GPS fix row
      LogEvent e; e.type = EV_GPS;
      e.p.gps.t_ms   = (uint32_t)millis();
      e.p.gps.unix_s = utc_time_valid() ? utc_now_s() : 0;
      e.p.gps.lat    = gpsLat;
      e.p.gps.lon    = gpsLon;
      e.p.gps.fix    = 1;
      e.p.gps.sync   = (syncEventFlag ? 1 : 0);

      if (!push_event(e)){ flushBuffers(true, FR_EMERGENCY); (void)push_event(e); }
      else { note_flush_thresholds(); }

      syncEventFlag   = false;
      stopGpsSession();
      lastGpsSampleMs = now;

    } else if (timed) {
      if (!retryUsed && sawRmcThisSession) {
        acqDeadline += GPS_RETRY_MS;   // one extra bite
        retryUsed = true;
      } else {
        // EV_GPS NaN row
        LogEvent e; e.type = EV_GPS;
        e.p.gps.t_ms   = (uint32_t)millis();
        e.p.gps.unix_s = utc_time_valid() ? utc_now_s() : 0;
        e.p.gps.lat    = NAN;
        e.p.gps.lon    = NAN;
        e.p.gps.fix    = 0;
        e.p.gps.sync   = 0;

        if (!push_event(e)){ flushBuffers(true, FR_EMERGENCY); (void)push_event(e); }
        else { note_flush_thresholds(); }

        stopGpsSession();
        lastGpsSampleMs = now;
      }
    }
  }

  // ----- ADXL345 FIFO polling (no INT pin) -----
#if !ACCEL_USE_FIFO_INT
  if ((int32_t)(now - nextAccelPollDue) >= 0){
    nextAccelPollDue = now + g_accel_poll_period_ms;
    service_accel_fifo();  // drain all queued samples in one burst
  }
#else
  // If/when you wire the INT pin:
  if (g_accelIntFlag){
    g_accelIntFlag = false;
    service_accel_fifo();
  }
#endif

  // ----- Time-based guard (keeps data moving at very low rates) -----
  if (RING_CAP_BYTES){
    bool needTime = (FLUSH_MAX_HOLD_MS>0) && (now - lastFlushMs >= FLUSH_MAX_HOLD_MS) && (!inQuietMode());
    if (needTime) flushBuffers(false, FR_MAXHOLD);
  }

  // ----- Low-power sleep until the next interesting moment -----
  uint32_t nextBle = bleActive ? (bleStartMs + BLE_ACTIVE_MS) : (lastBleCycleStartMs + BLE_CYCLE_PERIOD_MS);
  uint32_t nextGps = gpsSessionActive
                     ? min(gpsSessionStart + GPS_WARMUP_MS, acqDeadline)
                     : (lastGpsSampleMs + GPS_SAMPLE_PERIOD_MS);
  uint32_t deadline = min(nextBle, nextGps);
#if !ACCEL_USE_FIFO_INT
  deadline = min(deadline, nextAccelPollDue);
#endif

  if ((int32_t)(deadline - now) > 0) lowPowerIdleUntil(deadline);
  else sd_app_evt_wait();
}
