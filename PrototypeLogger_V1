// ====================================================================
// Unified event ring (types + storage + helpers) — dynamic capacity
// ====================================================================
enum EventType : uint8_t { EV_ACCEL=1, EV_GPS=2, EV_BLE=3 };

struct AccelRow { uint32_t t_ms; uint32_t unix_s; float ax, ay, az; };
struct GPSRow   { uint32_t t_ms; uint32_t unix_s; float lat, lon; uint8_t fix, sync; };
struct BLERow   { uint32_t t_ms; uint32_t unix_s; uint8_t mac[6]; int8_t rssi; };

// Union sized to largest payload
union EventPayload { AccelRow accel; GPSRow gps; BLERow ble; };

// Renamed from "Event" to avoid any library collisions
struct LogEvent { EventType type; EventPayload p; };

// Dynamic ring buffer fields
static LogEvent* g_events      = nullptr;
static size_t    g_event_cap   = 0;     // max number of events allocated
static size_t    g_event_count = 0;

static size_t    RING_CAP_BYTES  = 0;   // g_event_cap * sizeof(LogEvent)
static size_t    NORMAL_THRESH_B = 0;   // 85% of capacity
static size_t    EMERG_THRESH_B  = 0;   // 87.25%

// Fallback (only used if heap alloc fails)
#define FALLBACK_EVENT_MAX 512
static LogEvent g_events_fallback[FALLBACK_EVENT_MAX];

// Max hold guard (forces occasional flush at very low rates)
#define FLUSH_MAX_HOLD_MS 30000UL  // set to 0 to disable

inline size_t  ring_used_bytes()   { return g_event_count * sizeof(LogEvent); }
inline uint8_t ring_fullness_pct() { return (RING_CAP_BYTES ? (uint8_t)((ring_used_bytes() * 100U) / RING_CAP_BYTES) : 100); }

// Flush hint (set on each push; serviced in loop())
volatile uint8_t g_flushHint = 0; // 0 none, 1 normal, 2 emergency

inline void note_flush_thresholds() {
  size_t usedB = ring_used_bytes();
  if (usedB >= EMERG_THRESH_B) g_flushHint = 2;
  else if (usedB >= NORMAL_THRESH_B && g_flushHint < 2) g_flushHint = 1;
}

// Probe allocator for largest contiguous block we can get now
size_t find_max_contiguous_block(size_t max_limit = (1u<<21)) {
  size_t ok = 0;
  size_t trySize = 1024; // 1 KB start
  void* p = nullptr;
  while (trySize <= max_limit) {
    p = os_malloc(trySize);
    if (!p) break;
    os_free(p);
    ok = trySize;
    trySize <<= 1;
  }
  size_t lo = ok, hi = trySize;
  while (hi > lo + 1024) {
    size_t mid = lo + (hi - lo)/2;
    p = os_malloc(mid);
    if (p) { os_free(p); lo = mid; }
    else   { hi = mid; }
  }
  return lo;
}

bool push_event(const LogEvent& e){
  if (!g_events || g_event_count >= g_event_cap) return false;
  g_events[g_event_count++] = e;
  return true;
}

void alloc_event_ring_from_heap(){
  size_t maxBlock = find_max_contiguous_block();
  const size_t reserve = 8 * 1024;                   // ~8 KB safety headroom
  size_t usable = (maxBlock > reserve) ? (maxBlock - reserve) : (maxBlock / 2);

  size_t cap = usable / sizeof(LogEvent);
  const size_t min_events = 256;
  const size_t max_events = 8000;                    // safety upper bound
  if (cap < min_events) cap = min_events;
  if (cap > max_events) cap = max_events;

  for (int tries = 0; tries < 6; ++tries) {
    g_events = (LogEvent*) os_malloc(cap * sizeof(LogEvent));
    if (g_events) break;
    cap = (cap * 95) / 100;                          // back off 5%
    if (cap < min_events) break;
  }

  if (!g_events) {
    g_events     = g_events_fallback;
    g_event_cap  = FALLBACK_EVENT_MAX;
  } else {
    g_event_cap  = cap;
  }

  RING_CAP_BYTES  = g_event_cap * sizeof(LogEvent);
  NORMAL_THRESH_B = (RING_CAP_BYTES * 85)   / 100;   // 85.00%
  EMERG_THRESH_B  = (RING_CAP_BYTES * 8725) / 10000; // 87.25%

  Serial.print("Event size="); Serial.print((int)sizeof(LogEvent));
  Serial.print(" bytes, ring events="); Serial.print(g_event_cap);
  Serial.print(" ("); Serial.print((unsigned long)RING_CAP_BYTES); Serial.println(" bytes)");
  Serial.print("Flush thresholds: normal @ "); Serial.print((unsigned long)NORMAL_THRESH_B);
  Serial.print(" B (85%), emergency @ "); Serial.print((unsigned long)EMERG_THRESH_B);
  Serial.println(" B (87.25%)");
}

