// ====================================================================
// GNSS time discipline hook (called from parseRMC)
// ====================================================================
void time_on_gps_utc(int yyyy, int mo, int dd, int hh, int mi, int ss){
  if (!plausibleYear(yyyy)) return;
  uint64_t gps_utc_ms = unix_ms_from_ymdhms(yyyy, mo, dd, hh, mi, ss);
  uint64_t now_ms     = uptime_ms64();

  double pred_ms = g_clock.phase_ms + g_clock.scale * (double)(now_ms - g_clock.t0_ms);
  double err_ms  = (double)gps_utc_ms - pred_ms;

  const double SLEW_CAP_MS = 50.0;
  if (err_ms < -SLEW_CAP_MS) err_ms = -SLEW_CAP_MS;
  if (err_ms >  SLEW_CAP_MS) err_ms =  SLEW_CAP_MS;
  g_clock.phase_ms += err_ms;

  static bool have_ref=false; static uint64_t ref_uptime=0, ref_gps=0;
  if (!have_ref){ have_ref=true; ref_uptime=now_ms; ref_gps=gps_utc_ms; }
  uint64_t du = now_ms - ref_uptime, dg = gps_utc_ms - ref_gps;
  if (du >= 60000ULL){
    double meas_scale = (double)dg / (double)du;      // ms/ms
    const double A = 0.02;
    g_clock.scale = (1.0 - A)*g_clock.scale + A*meas_scale;
    ref_uptime = now_ms; ref_gps = gps_utc_ms;
  }

  g_clock.t0_ms  = now_ms;
  g_clock.synced = true;

  timeSynced    = true;
  syncEventFlag = true;
  noFlushUntilMs = millis() + QUIET_AFTER_SYNC_MS;
}

// ====================================================================
// ADXL345 (I2C) + FIFO helpers
// ====================================================================
static uint8_t ADXL_ADDR=0x1D; // auto-probe to 0x53 if needed
bool i2cWrite8(uint8_t a,uint8_t r,uint8_t v){ Wire.beginTransmission(a); Wire.write(r); Wire.write(v); return Wire.endTransmission()==0; }
bool i2cReadBytes(uint8_t a,uint8_t r,uint8_t* b,size_t n){
  Wire.beginTransmission(a); Wire.write(r);
  if(Wire.endTransmission(false)!=0) return false;
  size_t got=Wire.requestFrom((int)a,(int)n);
  for(size_t i=0;i<got && i<n;i++) b[i]=Wire.read();
  return got==n;
}
uint8_t i2cRead8(uint8_t a,uint8_t r){ uint8_t v=0; i2cReadBytes(a,r,&v,1); return v; }

bool adxl_init(){
  uint8_t id=i2cRead8(ADXL_ADDR,0x00);
  if(id!=0xE5){ ADXL_ADDR=(ADXL_ADDR==0x1D)?0x53:0x1D; id=i2cRead8(ADXL_ADDR,0x00); if(id!=0xE5) return false; }

  // 12.5 Hz, LOW_POWER=1
  i2cWrite8(ADXL_ADDR,0x2C,0x17); // BW_RATE
  i2cWrite8(ADXL_ADDR,0x31,0x00); // DATA_FORMAT: ±2g, 10-bit
  i2cWrite8(ADXL_ADDR,0x2D,0x08); // POWER_CTL: MEASURE=1

  // FIFO stream mode + watermark
  uint8_t wm = (ACCEL_FIFO_WATERMARK < 1) ? 1 : (ACCEL_FIFO_WATERMARK > 32 ? 32 : ACCEL_FIFO_WATERMARK);
  i2cWrite8(ADXL_ADDR, 0x38, (0b10<<6) | (wm & 0x1F));  // FIFO_CTL: STREAM + watermark

#if ACCEL_USE_FIFO_INT
  i2cWrite8(ADXL_ADDR, 0x2E, 0x02);   // INT_ENABLE: WATERMARK
  i2cWrite8(ADXL_ADDR, 0x2F, 0x00);   // INT_MAP: WATERMARK -> INT1
#else
  i2cWrite8(ADXL_ADDR, 0x2E, 0x00);   // INT_ENABLE: none   <-- fixed
#endif

  (void)i2cRead8(ADXL_ADDR, 0x30);    // Clear any latched INT_SOURCE
  return true;
}

inline float to_g(int16_t c){ return c*0.0039f; }

#if ACCEL_USE_FIFO_INT
volatile bool g_accelIntFlag = false;
void accel_isr(){ g_accelIntFlag = true; }
#endif

// Read up to 32 samples from FIFO in one I2C burst; timestamp evenly at ODR.
void service_accel_fifo(){
  (void)i2cRead8(ADXL_ADDR, 0x30); // Ack/clear latched source (harmless in polling)

  uint8_t fifo_status = i2cRead8(ADXL_ADDR, 0x39);
  uint8_t n = fifo_status & 0x3F;          // 0..32
  if (n == 0) return;
  if (n > 32) n = 32;

  const uint16_t bytes = 6 * n;
  uint8_t buf[6*32];
  if (!i2cReadBytes(ADXL_ADDR, 0x32, buf, bytes)) return;

  const uint32_t period = ACCEL_PERIOD_MS;
  const uint32_t now_ms = millis();
  const uint32_t first_ts = now_ms - (uint32_t)(n-1)*period;

  for (uint8_t i = 0; i < n; i++){
    const uint8_t* b = &buf[6*i];
    int16_t x = (int16_t)(b[1]<<8 | b[0]);
    int16_t y = (int16_t)(b[3]<<8 | b[2]);
    int16_t z = (int16_t)(b[5]<<8 | b[4]);

    LogEvent e; e.type = EV_ACCEL;
    e.p.accel.t_ms   = first_ts + (uint32_t)i*period;
    e.p.accel.unix_s = utc_time_valid() ? utc_now_s() : 0;
    e.p.accel.ax     = to_g(x);
    e.p.accel.ay     = to_g(y);
    e.p.accel.az     = to_g(z);

    if (!push_event(e)) { flushBuffers(true, FR_EMERGENCY); (void)push_event(e); }
    else { note_flush_thresholds(); }
  }

  // Optional: if (n == 32) Serial.println("[ACCEL] FIFO full at read (possible drops)");
}

// ====================================================================
// GPS standby/wake (u-blox UBX)
// ====================================================================
void sendUBX(uint8_t cls, uint8_t id, const uint8_t* payload, uint16_t len){
  uint8_t ckA = 0, ckB = 0;
  auto upd = [&](uint8_t b){ ckA = ckA + b; ckB = ckB + ckA; Serial1.write(b); };
  Serial1.write(0xB5); Serial1.write(0x62);
  upd(cls); upd(id);
  upd(len & 0xFF); upd((len >> 8) & 0xFF);
  for(uint16_t i=0;i<len;i++) upd(payload[i]);
  Serial1.write(ckA); Serial1.write(ckB);
}
// UBX-RXM-PMREQ (0x02 0x41): version=0, duration=0; flags.force=1; wakeupSources.uartrx=1
void gpsStandby(){
  uint8_t p[16]; memset(p, 0, sizeof(p));
  uint32_t flags = (1u << 2); // force
  memcpy(&p[8],  &flags, 4);
  uint32_t wake  = (1u << 3); // uartrx
  memcpy(&p[12], &wake,  4);
  sendUBX(0x02, 0x41, p, sizeof(p));
  Serial1.flush();
}
void gpsWake(){ Serial1.write('\r'); Serial1.write('\n'); Serial1.flush(); }

