static inline uint16_t BLE_UNITS(float ms) { return (uint16_t)((ms / 0.625f) + 0.5f); }
void macToStrMSB(const uint8_t macLE[6], char out[18]) {
  static const char kHexChars[] = "0123456789ABCDEF";
  int o=0;
  for(int i=5;i>=0;--i){
    uint8_t b = macLE[i];
    out[o++] = kHexChars[(b>>4)&0x0F];
    out[o++] = kHexChars[b&0x0F];
    if(i) out[o++]=':';
  }
  out[o]='\0';
}

// Scan state
bool     bleActive = false;
uint32_t bleStartMs = 0;
uint32_t lastBleCycleStartMs = 0;

// Forward decl for flush used in callback
void startBleScan();
void stopBleScan();

// BLE report callback
void scan_callback(ble_gap_evt_adv_report_t* report)
{
  if (mscMode) { Bluefruit.Scanner.resume(); return; }

  bool allow_log =
  #if BLE_DEDUP_PER_WINDOW
    should_log_and_remember(report->peer_addr.addr);
  #else
    true;
  #endif

  if (allow_log){
    LogEvent e; e.type = EV_BLE;
    e.p.ble.t_ms   = (uint32_t)millis();
    e.p.ble.unix_s = utc_time_valid() ? utc_now_s() : 0;
    memcpy(e.p.ble.mac, report->peer_addr.addr, 6);
    e.p.ble.rssi   = report->rssi;

    if (!push_event(e)){ flushBuffers(true, FR_EMERGENCY); (void)push_event(e); }
    else { note_flush_thresholds(); }
  }
  Bluefruit.Scanner.resume();
}

void startBleScan() {
  if (mscMode || bleActive) return;
  #if BLE_DEDUP_PER_WINDOW
    bleSeenCount = 0;
  #endif
  Bluefruit.Scanner.start(0);       // indefinite; stop after BLE_ACTIVE_MS
  bleStartMs = millis();
  bleActive  = true;
}
void stopBleScan() {
  if (!bleActive) return;
  Bluefruit.Scanner.stop();
  bleActive = false;
  lastBleCycleStartMs = millis();
}

// ====================================================================
// SD bus helpers + session open/close
// ====================================================================
static inline void sd_spi_bus_wake(){
  if (sdBusAwake) return;
  pinMode(SD_CS_PIN, OUTPUT);
  digitalWrite(SD_CS_PIN, HIGH);  // de-select card
  SPI.begin();
  delayMicroseconds(5);
  sdBusAwake = true;
}

static inline void sd_spi_bus_sleep(){
  if (!sdBusAwake) return;
  digitalWrite(SD_CS_PIN, HIGH);
  pinMode(SD_CS_PIN, INPUT_PULLUP);   // ensure de-selected
  SPI.end();
  pinMode(MOSI, INPUT);
  pinMode(SCK,  INPUT);
  pinMode(MISO, INPUT_PULLUP);
  sdBusAwake = false;
}

static bool sd_session_begin(){
  if (mscMode) return false;      // logging paused during MSC
  sd_spi_bus_wake();
  if (!sd.begin(sdCfg)) {
    sdOK = false;
    sd_spi_bus_sleep();
    return false;
  }
  sdOK = true;

  accelFile = sd.open(ACCEL_FILE, O_RDWR | O_CREAT | O_AT_END);
  gpsFile   = sd.open(GPS_FILE,   O_RDWR | O_CREAT | O_AT_END);
  bleFile   = sd.open(BLE_FILE,   O_RDWR | O_CREAT | O_AT_END);

  if (accelFile && accelFile.fileSize()==0) accelFile.println("t_ms,unix_s,ax,ay,az");
  if (gpsFile   && gpsFile.fileSize()==0)   gpsFile.println("t_ms,unix_s,lat,lon,fix,sync");
  if (bleFile   && bleFile.fileSize()==0)   bleFile.println("t_ms,unix_s,mac,rssi");

  return (bool)accelFile || (bool)gpsFile || (bool)bleFile;
}

static void sd_session_end(){
  if (accelFile) { accelFile.flush(); accelFile.close(); }
  if (gpsFile)   { gpsFile.flush();   gpsFile.close(); }
  if (bleFile)   { bleFile.flush();   bleFile.close(); }

  // Only sleep the bus if MSC is not active.
  if (!mscMode) sd_spi_bus_sleep();
}

