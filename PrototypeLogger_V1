// NMEA parsing + pump (placed AFTER globals so users are declared)
// ====================================================================
static inline int hexval(char h){
  if(h>='0' && h<='9') return h-'0';
  h = toupper((unsigned char)h);
  if(h>='A' && h<='F') return h-'A'+10;
  return -1;
}
bool nmeaChecksumOk(const char* s){
  const char* star = strrchr(s, '*');
  if(!s || s[0] != '$' || !star || star[1] == 0 || star[2] == 0) return false;
  uint8_t cs=0;
  for(const char* p=s+1; p<star; ++p) cs ^= (uint8_t)(*p);
  int want = (hexval(star[1])<<4) | hexval(star[2]);
  return want>=0 && cs == (uint8_t)want;
}
float nmeaCoord(const char* ddmm){
  if(!ddmm||!*ddmm) return NAN;
  const char* dot=strchr(ddmm,'.'); if(!dot) return NAN;
  int degDigits=((dot-ddmm)>4)?3:2; char db[4]={0}; strncpy(db,ddmm,degDigits);
  int deg=atoi(db); float mins=atof(ddmm+degDigits);
  return deg + mins / 60.0f;
}
int  fullYearFromYY(int yy); // already defined above
void parseRMC(char* s){
  // $--RMC,time,status,lat,NS,lon,EW,speed,cog,date,...
  char* p=strchr(s,','); if(!p) return; *p++=0; char* timestr=p;
  p=strchr(p,','); if(!p) return; *p++=0; char* status=p;
  p=strchr(p,','); if(!p) return; *p++=0; char* latF=p;
  p=strchr(p,','); if(!p) return; *p++=0; char* ns=p;
  p=strchr(p,','); if(!p) return; *p++=0; char* lonF=p;
  p=strchr(p,','); if(!p) return; *p++=0; char* ew=p;
  p=strchr(p,','); if(!p) return; *p++=0; p=strchr(p,','); if(!p) return; *p++=0; char* datestr=p;

  bool valid = (*status=='A');
  float lat = nmeaCoord(latF), lon = nmeaCoord(lonF);
  if(ns&&*ns=='S') lat=-lat; if(ew&&*ew=='W') lon=-lon;

  if(valid && !isnan(lat) && !isnan(lon)){
    gpsValid = true; gpsLat = lat; gpsLon = lon; lastValidRmcMs = millis();
    if (lastValidRmcMs >= gpsSessionStart) sawRmcThisSession = true;

    int hh=0,mi=0,ss=0,dd=1,mo=1,yy=0;
    if(timestr && strlen(timestr)>=6){ hh=(timestr[0]-'0')*10+(timestr[1]-'0'); mi=(timestr[2]-'0')*10+(timestr[3]-'0'); ss=(timestr[4]-'0')*10+(timestr[5]-'0'); }
    if(datestr && strlen(datestr)>=6){ dd=(datestr[0]-'0')*10+(datestr[1]-'0'); mo=(datestr[2]-'0')*10+(datestr[3]-'0'); yy=(datestr[4]-'0')*10+(datestr[5]-'0'); }
    int yyyy = fullYearFromYY(yy);

    time_on_gps_utc(yyyy, mo, dd, hh, mi, ss); // discipline clock
  } else {
    gpsValid = false;
  }
}
void pumpGPS(){
  while(Serial1.available()){
    int c=Serial1.read(); if(c<0) break; if(c=='\r') continue;
    if(c=='\n'){
      if(!nmeaOverflow){
        nmeaLine[min(nmeaIdx,NMEA_MAX-1)] = '\0';
        if (nmeaLine[0]=='$' && strstr(nmeaLine, "RMC") && nmeaChecksumOk(nmeaLine)){
          parseRMC(nmeaLine);
        }
      }
      nmeaIdx=0; nmeaOverflow=false;
    } else {
      if(nmeaIdx < NMEA_MAX-2) nmeaLine[nmeaIdx++] = (char)c;
      else nmeaOverflow = true; // discard this sentence until newline
    }
  }
}

